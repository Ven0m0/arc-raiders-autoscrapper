{
  "lspServers": {
    "python": {
      "command": "basedpyright-langserver",
      "args": ["--stdio"],
      "fileExtensions": { ".py": "python",  ".pyi": "python" }
    },
    "bash": {
      "command": "bash-language-server",
      "args": ["start"],
      "fileExtensions": { ".sh": "shellscript", ".bash": "shellscript", ".zsh": "shellscript" }
    },
    "json": {
      "command": "vscode-json-language-server",
      "args": ["--stdio"],
      "fileExtensions": { ".json": "python",  ".jsonc": "python" }
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": ["--stdio"],
      "fileExtensions": { ".yaml": "yaml", ".yml": "yaml" }
    },
    "toml": {
      "command": "tombi",
      "args": ["lsp"],
      "fileExtensions": { ".toml": "toml" }
    },
    "markdown-oxide": {
      "command": "markdown-oxide",
      "args": [],
      "fileExtensions": { ".md": "markdown" }
    },
    "rust": {
      "command": "rust-analyzer",
      "args": [],
      "fileExtensions": { ".rs": "rust" }
    },
    "typescript": {
      "command": "vtsls",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mts": "typescript",
        ".cts": "typescript",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    }
  }
}
