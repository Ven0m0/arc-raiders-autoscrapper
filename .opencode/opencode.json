{
  "$schema": "https://opencode.dev/schema.json",
  "project": {
    "name": "arc-raiders-autoscrapper",
    "description": "Desktop automation tool for Arc Raiders inventory management"
  },
  "workspace": {
    "allowedDirectories": [
      "C:\\Users\\Ven0m0\\project\\arc-raiders-autoscrapper"
    ]
  },
  "shell": {
    "nonInteractive": true,
    "env": {
      "CI": "true",
      "GIT_TERMINAL_PROMPT": "0",
      "GIT_PAGER": "cat",
      "PAGER": "cat"
    }
  },
  "validation": {
    "python": {
      "linter": "ruff",
      "command": "uv run ruff check"
    },
    "precommit": {
      "enabled": true,
      "command": "uv run pre-commit run --all-files"
    }
  },
  "hooks": {
    "autoLint": {
      "enabled": true,
      "patterns": ["src/**/*.py"],
      "command": "uv run ruff check --fix"
    }
  }
}
