  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".kilo/rules/*.md",
    "https://raw.githubusercontent.com/JRedeker/opencode-shell-strategy/trunk/shell_strategy.md"
  ],
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&}:": "deny",
    "doom_loop": "deny"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "default_agent": "plan",
  "agent": {
    "code": {
      "model": "minimax/minimax-m2.5:free",
      "temperature": 0.1
    },
    "debug": {
      "model": "minimax/minimax-m2.5:free",
      "temperature": 0.05
    },
    "plan": {
      "model": "qwen/qwen3.6-plus",
      "temperature": 0.15
    },
    "ask": {
      "model": "qwen/qwen3.6-plus",
      "temperature": 0.2
    },
    "explore": {
      "model": "morph/morph-v3-fast",
      "temperature": 0.0
    },
    "general": {
      "model": "qwen/qwen3.6-plus",
      "temperature": 0.15
    },
    "orchestrator": {
      "model": "qwen/qwen3.6-plus",
      "temperature": 0.1
    }
  },
  "lsp": {
    "typescript": {
      "command": ["vtsls", "--stdio"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs", ".mts", ".cts"],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    },
    "pyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "markdown-oxide": {
      "command": ["markdown-oxide"],
      "extensions": [".md", ".mdx"]
    },
    "json-ls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "dockerfile-ls": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile"]
    },
    "html-ls": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css-ls": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "tombi": {
      "command": ["tombi", "lsp"],
      "extensions": [".toml"]
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      ".ruff_cache/**",
      "uv.lock",
      "ocr_debug/**",
      "node_modules/**",
      "**/node_modules/**",
      ".omc/**",
      ".remember/**",
      ".cachebro/**"
    ]
  },
  "mcp": {
    "github-mcp-server": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "timeout": 30000,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}",
        "X-MCP-Insiders": "true",
        "X-MCP-Toolsets": "default,actions,web_search,code_security,copilot,dependabot,git,secret_protection,security_advisories,stargazers,github_support_docs_search,labels,gists"
      }
    },
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true,
      "oauth": false,
      "timeout": 30000,
      "headers": {
        "x-ref-api-key": "{env:REF_API_KEY}"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa",
      "enabled": true,
      "oauth": false,
      "timeout": 30000,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 30000
    }
  },
  "skills": {
    "paths": [".kilo/skill"]
  },
  "disabled_providers": ["openai"],
  "experimental": {
    "continue_loop_on_deny": true,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  },
  "plugin": [
    "opencode-image-compress@0.3.2",
    "opencode-ignore@1.1.0",
    "openslimedit@1.0.4",
    "opencode-pty@0.3.2",
    "@spoons-and-mirrors/subtask2@0.3.5",
    "opencode-session-handoff@1.1.6",
    "opencode-websearch@0.5.0",
    "openfundus@0.1.6",
    "opencode-toolbox@0.10.4",
    "opencode-cross-repo@0.4.1",
    "@tuanhung303/opencode-acp@3.0.15",
    "opencode-anthropic-oauth@0.4.1",
    "opencode-gemini-auth@1.4.9",
    "opencode-kilo-auth@1.1.4",
    "@gotgenes/opencode-agent-identity@3.0.1"
  ],
  "share": "manual"
