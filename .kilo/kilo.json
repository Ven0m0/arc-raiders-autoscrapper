{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [".kilo/rules/*.md", ".kilo/CROSS_REFERENCE.md", "AGENTS.md", ".github/instructions/*.md"],
  "skills": {
    "paths": [".kilo/skills", ".kilo/skill", ".opencode/skills", ".claude/skills"]
  },
  "permission": {
    "*": "allow",
    "read": { "*.env": "deny", "*.lock": "deny", "*": "allow" },
    "edit": { "dist/**": "deny", "*.lock": "deny", "*": "allow" },
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "provider": {
    "openai": {
      "options": { "apiKey": "{env:OPENAI_API_KEY}" }
    },
    "anthropic": {
      "options": { "apiKey": "{env:ANTHROPIC_API_KEY}" }
    }
  },
  "disabled_providers": ["openai", "google"],
  "plugin": [
    "opencode-ignore@1.1.0",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "github:kdcokenny/opencode-background-agents",
    "github:spoons-and-mirrors/subtask2",
    "./plugins/context-shield",
    "./plugins/gitingest",
    "./plugins/trim-tool-name",
    "./plugins/custom-tools",
    "./plugins/json-healer"
  ],
  "formatter": {
    "biome": {
      "command": ["npx", "-y", "@biomejs/biome", "check", "--write", "--format-with-errors=true", "$FILE"],
      "extensions": [".json", ".js"]
    },
    "ruff": {
      "command": ["uv", "run", "ruff", "format", "$FILE"],
      "extensions": [".py", ".pyi"]
    }
  },
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**", "__pycache__/**", ".ruff_cache/**"] },
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer {env:CONTEXT7_API_KEY}" },
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa",
      "enabled": true,
      "headers": { "x-api-key": "{env:EXA_API_KEY}" }
    },
    "fast-filesystem": {
      "type": "local",
      "command": ["npx", "-y", "fast-filesystem@latest"],
      "enabled": false
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "octocode": {
      "type": "local",
      "command": ["npx", "-y", "octocode-mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"],
      "enabled": false
    }
  },
  "lsp": {
    "basedpyright": {
      "command": ["uv", "run", "basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "ty": {
      "command": ["uv", "run", "ty", "check"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "vtsls": {
      "command": ["vtsls", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".mts"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "json-ls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "tombi": {
      "command": ["uv", "run", "tombi", "lsp"],
      "extensions": [".toml"]
    }
  },
  "compaction": { "auto": true, "prune": true },
  "experimental": {
    "continue_loop_on_deny": false,
    "codebase_search": true,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
