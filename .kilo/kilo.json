{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "disabled_providers": ["openai"],
  "plugin": [
    "openslimedit@1.0.4",
    "opencode-ignore@1.1.0",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "opencode-websearch@0.5.0"
  ],
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**"] },
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true
    },
    "github-mcp-server": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa",
      "enabled": true
    },
    "git-mcp": {
      "type": "remote",
      "url": "https://gitmcp.io/Ven0m0/arc-raiders-autoscrapper",
      "enabled": true
    }
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
