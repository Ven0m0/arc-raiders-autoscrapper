ActiveQuestsScreen,
ReviewQuestsScreen {
    padding: 1 2;
}

#quest-title,
#review-title {
    width: auto;
    text-style: bold;
    color: #7dd3fc;
}

#quest-filterbar,
#review-filterbar {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#quest-search,
#review-search {
    width: 1fr;
    margin-right: 1;
}

#quest-sort,
#review-sort {
    width: 20;
    text-style: bold;
}

#quest-list-summary,
#review-list-summary {
    margin-bottom: 1;
}

#quest-list,
#review-list {
    height: 1fr;
}

#quest-list > .option-list--option,
#review-list > .option-list--option {
    padding: 0 0 1 0;
}

#quest-list > .option-list--option-highlighted,
#review-list > .option-list--option-highlighted {
    text-style: bold;
}

#quest-actions,
#review-actions {
    margin-top: 1;
    height: auto;
}
