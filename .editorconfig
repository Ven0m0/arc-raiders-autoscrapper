root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 120
quote_type = auto
spelling_language = en
shell_variant = auto
curly_bracket_next_line = false
spaces_around_operators = true

[[shell],**/*.{sh,bash,zsh},PKGBUILD]
indent_style = space
indent_size = 2
tab_width = 2
shell_variant = bash
spaces_around_operators = true
spaces_around_brackets = false
binary_next_line = true
switch_case_indent = true
keep_padding = true
space_redirects = false
function_next_line = false
simplify = true
minify = true
never_split = true

[**/*.{bat,cmd,ps1,psm1}]
indent_style = space
indent_size = 4
end_of_line = crlf

[**/*.ahk]
end_of_line = crlf

[**/*.{py,pyw,pyi}]
indent_size = 4
indent_style = space
max_line_length = 88
quote_type = double

# XML / HTML
[**/*.{xml,html,htm}]
indent_size = 4

[**/*.{md,markdown}]
max_line_length = unset
trim_trailing_whitespace = false

[**/*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false

[**/*.{rst,txt}]
trim_trailing_whitespace = false

# Makefiles (require tabs)
[Makefile,**/*.mk]
indent_style = tab
indent_size = 4
tab_width = 4

# Lock files
[{bun.lockb,package-lock.json,uv.lock}]
insert_final_newline = true

[*.svg]
insert_final_newline = false
